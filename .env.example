# LLM（DeepSeek，OpenAI API 兼容）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Embedding 档位：local / api / disabled
# - local: 子进程 + BGE-M3，私有化部署，需要 torch + sentence-transformers
# - api:   OpenAI 兼容 embedding 服务，开发演示用
# - disabled: 零向量降级，单测/CI 用
EMBEDDING_PROVIDER=disabled
EMBEDDING_LOCAL_MODEL=BAAI/bge-m3
EMBEDDING_LOCAL_DEVICE=cpu
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_API_MODEL=text-embedding-3-small

# Neo4j（Docker Compose 中 API 容器会覆盖为 bolt://neo4j:7687）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# 向量后端：chroma / pgvector
VECTOR_STORE_TYPE=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
# PGVector（仅 VECTOR_STORE_TYPE=pgvector 时生效）
PGVECTOR_DSN=postgresql://postgres:postgres@localhost:5432/knowledge

# Kafka（CDC 增量更新用，不填则只能用 Watchdog 监听本地文件）
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DOC_CHANGES=doc-changes
KAFKA_TOPIC_KG_UPDATES=kg-updates

# API
API_HOST=0.0.0.0
API_PORT=8080

# 文档上传目录
# Docker Compose 中 API 容器会覆盖为 /app/uploads，并挂载到宿主机 ./uploads
UPLOAD_DIR=./uploads
